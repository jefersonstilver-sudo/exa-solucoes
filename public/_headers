/*
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://maps.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.supabase.co https://*.supabase.in https://www.examidia.com.br https://*.examidia.com.br; connect-src 'self' https://*.supabase.co https://*.supabase.in wss://*.supabase.co https://api.asaas.com https://maps.googleapis.com https://viacep.com.br https://brasilapi.com.br https://receitaws.com.br; frame-ancestors 'self'; base-uri 'self'; form-action 'self';

# HTML/SPA shell — always revalidate to avoid stale cache (Safari/iPhone)
/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# Catch-all para qualquer rota SPA que sirva o index.html (Safari macOS, Comet/Chromium)
/*.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

/sw.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/site.webmanifest
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

# Favicons / brand icons — must always revalidate to avoid stale brand assets
/favicon.ico
  Cache-Control: no-cache, must-revalidate
/favicon.png
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
/favicon-16x16.png
  Cache-Control: no-cache, must-revalidate
/favicon-32x32.png
  Cache-Control: no-cache, must-revalidate
/favicon-48x48.png
  Cache-Control: no-cache, must-revalidate
/favicon-96x96.png
  Cache-Control: no-cache, must-revalidate
/apple-touch-icon.png
  Cache-Control: no-cache, must-revalidate
/android-chrome-192x192.png
  Cache-Control: no-cache, must-revalidate
/android-chrome-512x512.png
  Cache-Control: no-cache, must-revalidate
/mstile-150x150.png
  Cache-Control: no-cache, must-revalidate
/safari-pinned-tab.svg
  Cache-Control: no-cache, must-revalidate
/browserconfig.xml
  Cache-Control: no-cache, must-revalidate

# Hashed/versioned build assets — long-lived immutable cache
/assets/*
  Cache-Control: public, max-age=31536000, immutable
